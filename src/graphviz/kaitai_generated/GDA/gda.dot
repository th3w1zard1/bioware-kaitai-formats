digraph {
	rankdir=LR;
	node [shape=plaintext];
	subgraph cluster__gda {
		label="Gda";
		graph[style=dotted];

		gda__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
			<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
			<TR><TD PORT="as_gff4_pos">0</TD><TD PORT="as_gff4_size">...</TD><TD>Gff::Gff4File</TD><TD PORT="as_gff4_type">as_gff4</TD></TR>
		</TABLE>>];
	}
	gda__seq:as_gff4_type -> gff4_file__seq [style=bold];
}
